generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  isAdmin      Boolean  @default(false)
  fullName     String?
  phone        String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  postalCode   String?
  country      String   @default("Portugal")

  newsletterOptIn   Boolean @default(false)
  orderUpdatesEmail Boolean @default(true)

  passwordHash String
  passwordSalt String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  passwordResetTokens PasswordResetToken[]
  wishlistItems       WishlistItem[]
  auditLogs           AuditLog[]      @relation("AuditActor")
  inventoryMovements  InventoryMovement[] @relation("InventoryActor")
  supportTickets      SupportTicket[]
  blogComments        BlogComment[]
  faqQuestions        FaqQuestion[]

  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@unique([tokenHash])
}

enum ProductCategory {
  colares
  brincos
  pulseiras
  aneis
  conjuntos
}

enum ProductMaterial {
  aco_inox
  prata
  dourado
  rose_gold
  perolas
  cristais
}

enum ProductStatus {
  active
  inactive
  out_of_stock
}

model Product {
  id            String        @id @default(cuid())
  name          String
  description   String?
  price         Decimal       @db.Decimal(12, 2)
  acquisitionCost Decimal?    @db.Decimal(12, 2)
  originalPrice Decimal?      @db.Decimal(12, 2)
  category      ProductCategory
  material      ProductMaterial?
  colors        String[]      @default([])
  images        String[]      @default([])
  videos        String[]      @default([])
  stock         Int           @default(0)
  freeShipping  Boolean       @default(false)
  isFeatured    Boolean       @default(false)
  isNew         Boolean       @default(false)
  isBestseller  Boolean       @default(false)
  status        ProductStatus @default(active)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  reviews       Review[]
  orderItems    OrderItem[]
  purchaseItems PurchaseItem[]
  inventoryMovements InventoryMovement[]
  productViews  ProductView[]

  @@index([category])
  @@index([status])
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
}

enum PaymentMethod {
  mbway
  transferencia
  multibanco
  paypal
}

model Order {
  id                String        @id @default(cuid())
  customerName      String
  customerEmail     String
  customerPhone     String?
  shippingAddress   String?
  shippingCity      String?
  shippingPostalCode String?
  shippingCountry   String        @default("Portugal")
  shippingMethodId  String?
  shippingMethodLabel String?
  trackingCode      String?
  trackingUrl       String?
  trackingCarrier   String?
  subtotal          Decimal?      @db.Decimal(12, 2)
  shippingCost      Decimal       @default(0) @db.Decimal(12, 2)
  total             Decimal       @db.Decimal(12, 2)
  status            OrderStatus   @default(pending)
  paymentMethod     PaymentMethod?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  items             OrderItem[]

  @@index([status])
  @@index([customerEmail])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  productName  String
  productImage String?
  price        Decimal  @db.Decimal(12, 2)
  quantity     Int
  color        String?

  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  rating     Int
  comment    String?
  authorName String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isApproved])
}

model WishlistItem {
  id           String   @id @default(cuid())
  userId       String?
  productId    String
  productName  String?
  productImage String?
  productPrice Decimal? @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userId    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([userId])
}

model ProductView {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([productId])
}

model SearchEvent {
  id             String   @id @default(cuid())
  query          String
  queryNormalized String
  userId         String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([queryNormalized])
  @@index([userId])
}

enum BlogCategory {
  tendencias
  dicas
  novidades
  inspiracao
}

enum BlogStatus {
  draft
  published
}

model SiteContent {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions FaqQuestion[]

  @@index([isActive])
  @@index([order])
  @@index([createdAt])
}

model FaqQuestion {
  id          String   @id @default(cuid())
  userId      String?
  authorName  String?
  authorEmail String?
  question    String
  answer      String?
  isPublic    Boolean  @default(false)
  faqItemId   String?
  answeredAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  faqItem     FaqItem? @relation(fields: [faqItemId], references: [id], onDelete: SetNull)

  @@index([isPublic])
  @@index([createdAt])
  @@index([answeredAt])
  @@index([userId])
  @@index([faqItemId])
}

model InstagramPost {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  coverUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

enum SupportTicketStatus {
  open
  closed
}

enum SupportMessageAuthorType {
  customer
  admin
}

model SupportTicket {
  id            String             @id @default(cuid())
  userId        String?
  customerName  String?
  customerEmail String?
  subject       String
  status        SupportTicketStatus @default(open)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages      SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([updatedAt])
}

model SupportMessage {
  id         String                 @id @default(cuid())
  ticketId   String
  authorType SupportMessageAuthorType
  authorId   String?
  message    String
  createdAt  DateTime               @default(now())

  ticket     SupportTicket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  link      String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]

  @@index([createdAt])
  @@index([name])
}

enum PurchaseStatus {
  draft
  received
  cancelled
}

model Purchase {
  id          String         @id @default(cuid())
  supplierId  String?
  reference   String?
  status      PurchaseStatus @default(draft)
  purchasedAt DateTime       @default(now())
  notes       String?
  total       Decimal?       @db.Decimal(12, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  supplier    Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items       PurchaseItem[]
  movements   InventoryMovement[]

  @@index([createdAt])
  @@index([purchasedAt])
  @@index([status])
  @@index([supplierId])
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  productId   String?
  productName String
  productImage String?
  unitCost    Decimal  @db.Decimal(12, 2)
  quantity    Int

  purchase  Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([productId])
}

enum InventoryMovementType {
  purchase
  manual
  order
}

model InventoryMovement {
  id             String                @id @default(cuid())
  productId      String
  type           InventoryMovementType
  quantityChange Int
  unitCost       Decimal?              @db.Decimal(12, 2)
  purchaseId     String?
  actorId        String?
  meta           Json?
  createdAt      DateTime              @default(now())

  product        Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchase       Purchase?             @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  actor          User?                 @relation("InventoryActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([productId])
  @@index([type])
  @@index([purchaseId])
  @@index([actorId])
}

model BlogPost {
  id        String       @id @default(cuid())
  title     String
  content   String
  excerpt   String?
  imageUrl  String?
  category  BlogCategory?
  status    BlogStatus   @default(draft)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  comments  BlogComment[]

  @@index([status])
  @@index([category])
}

model BlogComment {
  id          String   @id @default(cuid())
  postId      String
  userId      String?
  authorName  String
  authorEmail String?
  content     String
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  post        BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  replies     BlogCommentReply[]

  @@index([postId])
  @@index([userId])
  @@index([isApproved])
  @@index([createdAt])
}

enum BlogCommentReplyAuthorType {
  customer
  admin
}

model BlogCommentReply {
  id         String                   @id @default(cuid())
  commentId  String
  authorType BlogCommentReplyAuthorType
  authorId   String?
  message    String
  createdAt  DateTime                 @default(now())

  comment    BlogComment              @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType])
  @@index([actorId])
}
